---
layout: null
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">
  <url>
    <loc>{{ '/' | absolute_url }}</loc>
    <xhtml:link rel="alternate" hreflang="sk" href="{{ '/' | absolute_url }}"/>
    <xhtml:link rel="alternate" hreflang="en" href="{{ '/en/' | absolute_url }}"/>
    <xhtml:link rel="alternate" hreflang="x-default" href="{{ '/' | absolute_url }}"/>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
  </url>
  <url>
    <loc>{{ '/en/' | absolute_url }}</loc>
    <xhtml:link rel="alternate" hreflang="sk" href="{{ '/' | absolute_url }}"/>
    <xhtml:link rel="alternate" hreflang="en" href="{{ '/en/' | absolute_url }}"/>
    <xhtml:link rel="alternate" hreflang="x-default" href="{{ '/' | absolute_url }}"/>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
  </url>
</urlset>
